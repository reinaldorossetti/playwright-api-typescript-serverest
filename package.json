{
  "name": "playwright-api-typescript-serverest",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright API tests for ServeRest in TypeScript with Allure reports",
  "scripts": {
    "test": "playwright test",
    "test:login": "playwright test src/tests/features/login/login.spec.ts",
    "test:usuarios": "playwright test src/tests/features/usuarios/users.spec.ts",
    "test:produtos": "playwright test src/tests/features/produtos/products.spec.ts",
    "test:carrinhos": "playwright test src/tests/features/carrinhos/carts.spec.ts",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@faker-js/faker": "^9.8.0",
    "@playwright/test": "^1.58.0",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.4.1",
    "typescript": "^5.8.2"
  }
}
